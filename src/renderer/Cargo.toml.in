[package]
name = "renderer"
workspace = "@BUILD@"
version.workspace = true
edition.workspace = true
rust-version.workspace = true

[lints]
workspace = true

[lib]
path = "@SOURCE@/src/renderer/src/lib.rs"

[dependencies]
glow = { workspace = true }
naevc = { workspace = true }
nlog = { workspace = true }
ndata = { workspace = true }
anyhow = { workspace = true }
nalgebra = { workspace = true }
encase = { workspace = true }
sdl3 = { workspace = true }
image = { workspace = true }
naev_core = { workspace = true }
helpers = { workspace = true }
physics = { workspace = true }
mlua = { workspace = true }
palette = { workspace = true }
trie-rs = { workspace = true }
derive_more = { workspace = true }
softfloat = { workspace = true }
serde = { workspace = true }
serde-seeded = { workspace = true }
audio = { workspace = true }
fs-err = { workspace = true }
blake3 = { workspace = true }
bitcode = { workspace = true }
bytemuck = { workspace = true }
collide = { workspace = true }
resvg = "0.47"
naga = { version="28", features=["wgsl-in", "glsl-out"] }
tracing = { workspace = true }
tracing-mutex = { workspace = true }
# gltf-rs crate doesn't support WEBP in any release atm...
gltf = { version = "1.4", features = ["extras", "names", "utils", "EXT_texture_webp", "KHR_materials_emissive_strength"] }
